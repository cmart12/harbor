{
  "name": "intent",
  "version": "1.0.0",
  "description": "Quick intent capture from system tray",
  "productName": "Copilot Intent",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const p=require('path');['index.html','styles.css'].forEach(f=>fs.copyFileSync(p.join('src','renderer',f),p.join('dist','renderer',f)))\"",
    "postinstall": "bash scripts/codesign-dev.sh",
    "start": "npm run build && electron .",
    "dev": "npm run build && (tsc -w --preserveWatchOutput & node scripts/watch-assets.js & electron .)",
    "dev:packaged": "npm run build:mac && open build/mac-arm64/Copilot\\ Intent.app",
    "build:mac": "npm run build && electron-builder --mac --dir",
    "build:installer:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.copilot.intent",
    "productName": "Copilot Intent",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "src/assets",
        "to": "assets"
      }
    ],
    "mac": {
      "target": "dir",
      "category": "public.app-category.productivity",
      "entitlements": "scripts/entitlements.dev.plist",
      "entitlementsInherit": "scripts/entitlements.dev.plist",
      "extendInfo": {
        "LSUIElement": true,
        "NSMicrophoneUsageDescription": "Copilot Intent needs microphone access for voice input."
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@github/copilot-sdk": "^0.2.2",
    "@huggingface/transformers": "^4.1.0",
    "better-sqlite3": "^12.9.0",
    "onnxruntime-node": "^1.24.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/uuid": "^10.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "typescript": "^6.0.3"
  }
}
