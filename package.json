{
  "name": "intent",
  "version": "1.0.0",
  "description": "Quick intent capture from system tray",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const p=require('path');['index.html','styles.css'].forEach(f=>fs.copyFileSync(p.join('src','renderer',f),p.join('dist','renderer',f)))\"",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@github/copilot-sdk": "^0.2.2",
    "@huggingface/transformers": "^4.1.0",
    "better-sqlite3": "^12.9.0",
    "electron": "^41.2.1",
    "onnxruntime-node": "^1.24.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/uuid": "^10.0.0",
    "typescript": "^6.0.3"
  }
}
